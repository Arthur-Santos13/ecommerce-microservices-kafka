# ──────────────────────────────────────────────────────────────────────────────
# Environment variables for the ecommerce-microservices-kafka stack.
#
# Copy this file to .env and fill in production values before running:
#   cp .env.example .env
#
# .env is listed in .gitignore and must NEVER be committed to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Gateway ───────────────────────────────────────────────────────────────

# HMAC-SHA256 signing secret for JWT tokens.
# Generate with: openssl rand -base64 48
# Must be ≥ 32 characters.
JWT_SECRET=change-me-use-a-strong-random-32-char-minimum-secret

# Shared secret injected by the gateway into every proxied upstream request.
# Downstream services can verify X-Gateway-Secret to reject direct-access calls.
# Generate with: openssl rand -hex 32
GATEWAY_SECRET=change-me-use-a-strong-random-hex-secret

# Comma-separated list of allowed CORS origins (no trailing slash, no wildcards in production).
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com

# ── In-memory users (development / smoke-test only) ──────────────────────────

ADMIN_PASSWORD=change-me-admin-password
USER_PASSWORD=change-me-user-password

# ── Databases ─────────────────────────────────────────────────────────────────

POSTGRES_PASSWORD=change-me-postgres-password

# ── Kafka / ZooKeeper ─────────────────────────────────────────────────────────
# (No secrets required for a private network deployment; add SASL credentials here if needed.)

# ── Observability ─────────────────────────────────────────────────────────────
# LOGSTASH_HOST=logstash
# LOGSTASH_PORT=5000
