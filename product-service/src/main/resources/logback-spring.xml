<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Properties ─────────────────────────────────────────────────────── -->
    <springProperty name="appName"  source="spring.application.name" defaultValue="product-service"/>
    <property name="LOGSTASH_HOST"  value="${LOGSTASH_HOST:-localhost}"/>
    <property name="LOGSTASH_PORT"  value="${LOGSTASH_PORT:-5000}"/>

    <!-- ── Console appender (human-readable, for local development) ──────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{correlationId}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Logstash appender (JSON over TCP, for Docker/ELK) ─────────────── -->
    <appender name="LOGSTASH" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
        <destination>${LOGSTASH_HOST}:${LOGSTASH_PORT}</destination>
        <reconnectionDelay>10 seconds</reconnectionDelay>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${appName}"}</customFields>
            <includeMdcKeyName>correlationId</includeMdcKeyName>
        </encoder>
    </appender>

    <!-- ── Async wrapper keeps the Logstash appender off the request thread ─ -->
    <appender name="ASYNC_LOGSTASH" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="LOGSTASH"/>
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
    </appender>

    <!-- ── Root logger ───────────────────────────────────────────────────── -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <!-- Logstash appender is only activated when LOGSTASH_HOST env var is present -->
        <springProfile name="docker">
            <appender-ref ref="ASYNC_LOGSTASH"/>
        </springProfile>
    </root>

    <!-- ── Reduce noise from framework internals ─────────────────────────── -->
    <logger name="org.springframework"        level="WARN"/>
    <logger name="org.hibernate"              level="WARN"/>
    <logger name="org.flywaydb"               level="INFO"/>
    <logger name="com.ecommerce.product"      level="INFO"/>

</configuration>
